generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Address {
  id           Int       @id @default(autoincrement()) @map("address_id")
  userId       Int       @map("user_id")
  provinceCode String    @map("province_code") @db.VarChar(10)
  districtCode String    @map("district_code") @db.VarChar(10)
  wardCode     String    @map("ward_code") @db.VarChar(10)
  addressExtra String?   @map("address_extra") @db.VarChar(50)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  email        String    @default("") @db.VarChar(255)
  phone        String    @default("") @db.VarChar(20)
  receiverName String    @default("") @map("receiver_name") @db.VarChar(255)
  isDefault    Boolean   @default(false) @map("is_default")
  address      String?   @db.VarChar(500)
  street       String    @db.VarChar(100)
  updatedAt    DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_addresses_user")

  @@index([districtCode], map: "idx_addresses_district_code")
  @@index([provinceCode], map: "idx_addresses_province_code")
  @@index([userId], map: "idx_addresses_user_id")
  @@index([wardCode], map: "idx_addresses_ward_code")
  @@map("addresses")
}

model BannerTranslation {
  id           Int       @id @default(autoincrement()) @map("translation_id")
  bannerId     Int       @map("banner_id")
  languageCode String    @map("language_code") @db.VarChar(10)
  headline     String?   @db.VarChar(255)
  subHeadline  String?   @map("sub_headline")
  buttonText   String?   @map("button_text") @db.VarChar(100)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  banner       Banner    @relation(fields: [bannerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_banner_id")

  @@unique([bannerId, languageCode], map: "unique_banner_lang")
  @@index([bannerId], map: "idx_banner_translations_banner_id")
  @@index([languageCode], map: "idx_banner_translations_lang_code")
  @@map("banner_translations")
}

model Banner {
  id             Int                 @id @default(autoincrement()) @map("banner_id")
  name           String              @db.VarChar(255)
  imageUrl       String              @map("image_url") @db.VarChar(255)
  mobileImageUrl String?             @map("mobile_image_url") @db.VarChar(255)
  videoUrl       String?             @map("video_url") @db.VarChar(255)
  altText        String?             @map("alt_text") @db.VarChar(255)
  linkUrl        String?             @map("link_url") @db.VarChar(255)
  order          Int?                @default(0)
  startDate      DateTime?           @map("start_date") @db.Timestamptz(6)
  endDate        DateTime?           @map("end_date") @db.Timestamptz(6)
  isActive       Boolean?            @default(true) @map("is_active")
  createdAt      DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime?           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  publicId       String              @map("public_id") @db.VarChar(255)
  translations   BannerTranslation[]

  @@map("banners")
}

model Brand {
  id          Int       @id @default(autoincrement()) @map("brand_id")
  name        String?   @db.VarChar(100)
  description String?
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@index([id], map: "idx_brands_brand_id")
  @@map("brands")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model CartItem {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId           String           @map("cart_id") @db.Uuid
  variantId        String           @map("variant_id") @db.Uuid
  quantity         Int              @default(1)
  createdAt        DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  cart             Cart             @relation(fields: [cartId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cart_item_cart")
  product_variants product_variants @relation(fields: [variantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_variant")

  @@unique([cartId, variantId])
  @@index([cartId], map: "idx_cart_items_cart_id")
  @@index([variantId], map: "idx_cart_items_variant_id")
  @@map("cart_items")
}

model Cart {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    Int        @unique @map("user_id")
  createdAt DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime?  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  items     CartItem[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")

  @@index([userId], map: "idx_carts_user_id")
  @@map("carts")
}

model Category {
  id                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_id          String?               @db.Uuid
  image_public_id    String?               @db.VarChar(255)
  imageUrl           String?               @map("image_url")
  sort_order         Int?                  @default(0)
  is_active          Boolean?              @default(true)
  created_at         DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?             @default(now()) @db.Timestamptz(6)
  categories         Category?             @relation("categoriesTocategories", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_categories   Category[]            @relation("categoriesTocategories")
  translations       CategoryTranslation[]
  product_categories product_categories[]

  @@index([parent_id], map: "idx_categories_parent_id")
  @@map("categories")
}

model CategoryTranslation {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId   String    @map("category_id") @db.Uuid
  languageCode String    @map("language_code") @db.VarChar(5)
  name         String    @db.VarChar(255)
  slug         String    @unique(map: "unique_category_slug") @db.VarChar(255)
  description  String?
  category     Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  languages    languages @relation(fields: [languageCode], references: [code], onDelete: NoAction)

  @@unique([categoryId, languageCode], map: "unique_category_language")
  @@index([slug, languageCode], map: "idx_category_trans_slug_lang")
  @@map("category_translations")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model CheckoutSession {
  id        Int      @id @default(autoincrement())
  sessionId String   @unique @map("session_id") @db.Uuid
  userId    Int      @map("user_id")
  cartId    Int      @map("cart_id")
  status    String   @default("pending") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_checkout_user")

  @@index([cartId], map: "idx_checkout_cart_id")
  @@index([status], map: "idx_checkout_status")
  @@index([userId], map: "idx_checkout_user_id")
  @@map("checkout_sessions")
}

model ColorTranslation {
  id           Int    @id @default(autoincrement()) @map("color_translation_id")
  colorId      Int    @map("color_id")
  languageCode String @map("language_code") @db.VarChar(10)
  name         String @db.VarChar(50)
  color        Color  @relation(fields: [colorId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([colorId, languageCode])
  @@index([colorId], map: "idx_color_translations_color_id")
  @@map("color_translations")
}

model Color {
  id           Int                @id @default(autoincrement()) @map("color_id")
  hexCode      String?            @map("hex_code") @db.VarChar(7)
  translations ColorTranslation[]

  @@map("colors")
}

model MenuTranslation {
  id           Int       @id @default(autoincrement()) @map("translation_id")
  menuId       Int       @map("menu_id")
  languageCode String    @map("language_code") @db.VarChar(10)
  name         String    @db.VarChar(255)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  menu         Menu      @relation(fields: [menuId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_menu_translations_menu_id")

  @@unique([menuId, languageCode], map: "uk_menu_translations_menu_id_language_code")
  @@index([languageCode], map: "idx_menu_translations_locale")
  @@index([menuId], map: "idx_menu_translations_menu_id")
  @@map("menu_translations")
}

model Menu {
  id           Int               @id @default(autoincrement()) @map("menu_id")
  path         String            @db.VarChar(255)
  icon         String?           @db.VarChar(100)
  order        Int               @default(0)
  parentId     Int?              @map("parent_id")
  createdAt    DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime?         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  translations MenuTranslation[]
  parent       Menu?             @relation("MenuHierarchy", fields: [parentId], references: [id], onUpdate: NoAction, map: "fk_menus_parent_id")
  children     Menu[]            @relation("MenuHierarchy")

  @@index([parentId], map: "idx_menus_parent_id")
  @@map("menus")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model OrderItem {
  id        Int     @id @default(autoincrement()) @map("order_item_id")
  orderId   Int     @map("order_id")
  variantId Int     @map("variant_id")
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_order")

  @@index([orderId], map: "idx_order_items_order_id")
  @@index([variantId], map: "idx_order_items_variant_id")
  @@map("order_items")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Order {
  id            Int         @id @default(autoincrement()) @map("order_id")
  userId        Int         @map("user_id")
  addressId     Int         @map("address_id")
  note          String?
  paymentMethod String      @map("payment_method") @db.VarChar(20)
  shippingFee   Int         @default(0) @map("shipping_fee")
  totalAmount   Int         @map("total_amount")
  status        String      @default("pending") @db.VarChar(20)
  createdAt     DateTime?   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  items         OrderItem[]
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_orders_user")

  @@index([createdAt], map: "idx_orders_created_at")
  @@index([status], map: "idx_orders_status")
  @@index([userId], map: "idx_orders_user_id")
  @@map("orders")
}

model QuoteTranslation {
  id           Int       @id @default(autoincrement()) @map("translation_id")
  quoteId      Int       @map("quote_id")
  languageCode String    @map("language_code") @db.VarChar(10)
  content      String
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  quote        Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_quote_id")

  @@unique([quoteId, languageCode], map: "unique_quote_lang")
  @@map("quote_translations")
}

model Quote {
  id            Int                @id @default(autoincrement()) @map("quote_id")
  authorName    String             @map("author_name") @db.VarChar(100)
  source        String?            @db.VarChar(100)
  imageUrl      String?            @map("image_url") @db.VarChar(255)
  imagePublicId String?            @map("image_public_id") @db.VarChar(255)
  displayOrder  Int?               @default(0) @map("display_order")
  isActive      Boolean?           @default(true) @map("is_active")
  createdAt     DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  translations  QuoteTranslation[]

  @@map("quotes")
}

model SizeTranslation {
  id           Int    @id @default(autoincrement()) @map("size_translation_id")
  sizeId       Int    @map("size_id")
  languageCode String @map("language_code") @db.VarChar(10)
  name         String @db.VarChar(20)
  size         Size   @relation(fields: [sizeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([sizeId, languageCode])
  @@index([sizeId], map: "idx_size_translations_size_id")
  @@map("size_translations")
}

model Size {
  id           Int               @id @default(autoincrement()) @map("size_id")
  name         String            @default("") @db.VarChar(20)
  translations SizeTranslation[]

  @@map("sizes")
}

model User {
  id                         Int               @id @default(autoincrement()) @map("user_id")
  username                   String            @unique @db.VarChar(50)
  email                      String            @unique @db.VarChar(100)
  passwordHash               String            @map("password_hash") @db.VarChar(255)
  createdAt                  DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  refreshTokenHash           String?           @map("refresh_token_hash") @db.VarChar(255)
  refreshTokenExpiresAt      DateTime?         @map("refresh_token_expires_at") @db.Timestamptz(6)
  isVerified                 Boolean?          @default(false) @map("is_verified")
  verificationToken          String?           @map("verification_token") @db.VarChar(255)
  verificationTokenExpiresAt DateTime?         @map("verification_token_expires_at") @db.Timestamptz(6)
  resetToken                 String?           @unique @map("reset_token") @db.VarChar(255)
  resetTokenExpire           DateTime?         @map("reset_token_expire") @db.Timestamptz(6)
  role                       user_role         @default(user)
  avatar_url                 String?           @db.VarChar(255)
  public_id                  String?           @db.VarChar(255)
  addresses                  Address[]
  cart                       Cart?
  checkoutSessions           CheckoutSession[]
  orders                     Order[]
  wishlists                  wishlists[]

  @@map("users")
}

model VariantImage {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId        String           @map("variant_id") @db.Uuid
  publicId         String           @map("public_id") @db.VarChar(255)
  url              String
  width            Int?
  height           Int?
  format           String?          @db.VarChar(10)
  displayOrder     Int?             @default(0) @map("display_order")
  is_main          Boolean?         @default(false)
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  product_variants product_variants @relation(fields: [variantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([variantId], map: "idx_variant_images_variant_id")
  @@index([publicId], map: "idx_variant_images_public_id")
  @@map("variant_images")
}

model blogs {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String     @db.VarChar(255)
  slug          String     @unique @db.VarChar(255)
  excerpt       String?
  content       String
  thumbnail_url String?
  author_id     String?    @db.Uuid
  status        String?    @default("draft") @db.VarChar(20)
  view_count    Int?       @default(0)
  created_at    DateTime?  @default(now()) @db.Timestamp(6)
  updated_at    DateTime?  @default(now()) @db.Timestamp(6)
  published_at  DateTime?  @db.Timestamp(6)
  comments      comments[]
}

model comments {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blog_id    String?   @db.Uuid
  user_id    String?   @db.Uuid
  content    String
  created_at DateTime? @default(now()) @db.Timestamp(6)
  blogs      blogs?    @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model tags {
  id   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String? @db.VarChar(100)
  slug String? @unique @db.VarChar(100)
}

model attribute_translations {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attribute_id  String     @db.Uuid
  language_code String     @db.VarChar(5)
  name          String     @db.VarChar(100)
  attributes    attributes @relation(fields: [attribute_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  languages     languages  @relation(fields: [language_code], references: [code], onDelete: NoAction)

  @@unique([attribute_id, language_code], map: "unique_attribute_language")
  @@index([language_code], map: "idx_attr_translations_lang")
}

model attribute_value_translations {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attribute_value_id String           @db.Uuid
  language_code      String           @db.VarChar(5)
  name               String           @db.VarChar(50)
  attribute_values   attribute_values @relation(fields: [attribute_value_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  languages          languages        @relation(fields: [language_code], references: [code], onDelete: NoAction)

  @@unique([attribute_value_id, language_code], map: "unique_attr_value_language")
  @@index([language_code], map: "idx_attr_val_trans_lang")
}

model attribute_values {
  id                           String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attribute_id                 String                         @db.Uuid
  value_code                   String                         @db.VarChar(100)
  sort_order                   Int?                           @default(0)
  created_at                   DateTime?                      @default(now()) @db.Timestamptz(6)
  attribute_value_translations attribute_value_translations[]
  attributes                   attributes                     @relation(fields: [attribute_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([attribute_id], map: "idx_attr_values_attribute_id")
  @@index([sort_order], map: "idx_attr_values_sort")
}

model attributes {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                   String                   @db.VarChar(50)
  display_type           attribute_display_type?  @default(text)
  created_at             DateTime?                @default(now()) @db.Timestamptz(6)
  attribute_translations attribute_translations[]
  attribute_values       attribute_values[]

  @@index([slug], map: "idx_attributes_slug")
}

model languages {
  code                         String                         @id @db.VarChar(5)
  name                         String                         @db.VarChar(50)
  is_default                   Boolean?                       @default(false)
  is_active                    Boolean?                       @default(true)
  created_at                   DateTime?                      @default(now()) @db.Timestamptz(6)
  attribute_translations       attribute_translations[]
  attribute_value_translations attribute_value_translations[]
  category_translations        CategoryTranslation[]
  product_translations         product_translations[]
}

model product_translations {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id    String    @db.Uuid
  language_code String    @db.VarChar(5)
  name          String    @db.VarChar(255)
  slug          String    @unique(map: "unique_product_slug") @db.VarChar(255)
  description   String?
  content       String?
  languages     languages @relation(fields: [language_code], references: [code], onDelete: NoAction)
  products      products  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([product_id, language_code], map: "unique_product_language")
  @@index([name], map: "idx_product_translations_name")
  @@index([slug, language_code], map: "idx_product_translations_slug_lang")
}

model product_variants {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id       String          @db.Uuid
  sku              String          @unique @db.VarChar(100)
  price            Decimal         @default(0) @db.Decimal(12, 2)
  compare_at_price Decimal?        @db.Decimal(12, 2)
  discount_percent Int?            @default(dbgenerated("\nCASE\n    WHEN (compare_at_price > price) THEN round((((compare_at_price - price) / compare_at_price) * (100)::numeric))\n    ELSE (0)::numeric\nEND"))
  stock            Int             @default(0)
  option_value_ids Json
  status           product_status? @default(active)
  created_at       DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?       @default(now()) @db.Timestamptz(6)
  cart_items       CartItem[]
  products         products        @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  variant_images   VariantImage[]
  wishlists        wishlists[]

  @@index([option_value_ids], map: "idx_variants_options", type: Gin)
  @@index([product_id], map: "idx_variants_product_id")
  @@index([sku], map: "idx_variants_sku")
}

model products {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status               product_status?        @default(active)
  created_at           DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?              @default(now()) @db.Timestamptz(6)
  deleted_at           DateTime?              @db.Timestamptz(6)
  best_reviewed        Boolean?               @default(false)
  best_seller          Boolean?               @default(false)
  new_arrival          Boolean?               @default(true)
  product_categories   product_categories[]
  product_translations product_translations[]
  product_variants     product_variants[]

  @@index([created_at(sort: Desc)], map: "idx_products_created_at")
  @@index([status], map: "idx_products_status")
}

model product_categories {
  product_id  String   @db.Uuid
  category_id String   @db.Uuid
  categories  Category @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products    products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([product_id, category_id])
  @@index([category_id], map: "idx_product_categories_category_id")
}

model wishlists {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          Int
  variant_id       String           @db.Uuid
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  users            User             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_wishlist_user")
  product_variants product_variants @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_wishlist_variant")

  @@unique([user_id, variant_id], map: "unique_user_variant")
  @@index([user_id], map: "idx_wishlist_user_id")
}

enum user_role {
  user
  admin
  ad
  superadmin
}

enum attribute_display_type {
  text
  color
  image
  dropdown
}

enum product_status {
  active
  inactive
  archived
}
